# Single HTTPS dev entry: Hono on :3000, Vite on :5273 (this repo’s defaults).
# See dev/caddy/README.md
#
# From repo root:
#   caddy run --config dev/caddy/Caddyfile
#
# macOS: after first start with `tls internal`, run `caddy trust` so Safari
# accepts https://localhost:8443
#
# `protocols h1 h2` disables HTTP/3 in dev (simpler for some curl/openssl stacks).
{
	servers {
		protocols h1 h2
	}
}

# List loopback hostnames so `tls internal` issues a cert whose SANs include
# 127.0.0.1 and localhost — `curl -k https://127.0.0.1:8443` then works.
# LAN clients (e.g. https://192.168.x.x:8443) need a different cert; use
# Caddyfile.mkcert.example for that.
https://127.0.0.1:8443, https://localhost:8443, https://[::1]:8443 {
	# Access log: one JSON line per request/response to stdout (visible in `pnpm dev:caddy` terminal).
	log {
		level INFO
		output stdout
		format json
	}

	tls internal

	handle /api/* {
		reverse_proxy 127.0.0.1:3000
	}

	handle {
		reverse_proxy 127.0.0.1:5273
	}
}
